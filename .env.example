# Copy this file to .env before running the app

# MongoDB connection (Docker service)
MONGO_URI=mongodb://mongodb:27017/files-on-cloud

# JWT Secret (use a strong random string in production)
JWT_SECRET=your_jwt_secret_here

feature/docker-containerization

# Server port (optional, defaults to 10002)
PORT=10002

# Maximum file size in MB allowed for uploads (optional, defaults to 20)
MAX_FILE_SIZE_MB=20

# Salt used when hashing downloader IP addresses for analytics storage.
# Set to any random string to prevent rainbow-table reconstruction of IPs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_SALT=



# Brevo credentials 
BREVO_API_KEY = 
BREVO_SENDER_NAME=
# Sender email should be the account's email for which Brevo api key was created.
BREVO_SENDER_EMAIL=



PRODUCTION_CLIENT_URL=https://files-on-cloud.onrender.com


# for development - NODE_ENV=development, for deployment and production - NODE_ENV=production
NODE_ENV=

# Cloudinary Credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
